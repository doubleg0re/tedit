{
  "name": "tedit-tools",
  "version": "0.1.5",
  "description": "Structure-aware JSX/TSX editing for coding agents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doubleg0re/tedit.git"
  },
  "homepage": "https://github.com/doubleg0re/tedit#readme",
  "bugs": {
    "url": "https://github.com/doubleg0re/tedit/issues"
  },
  "bin": {
    "tedit": "dist/cli.js",
    "tedit-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "!*.bak",
    "!*.tedit.bak",
    "!**/*.bak",
    "!**/*.tedit.bak"
  ],
  "scripts": {
    "build": "tsc && node scripts/prepare-bin.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "npm run build && node --test tests/*.test.mjs",
    "dogfood:agent": "npm run build && node scripts/dogfood-agent-workflows.mjs",
    "dogfood:benchmark": "npm run build && node scripts/dogfood-benchmark.mjs",
    "dogfood:compare": "npm run build && node scripts/compare-edit-workflows.mjs",
    "release:smoke": "npm run build && node scripts/pack-check.mjs",
    "pack:check": "npm run release:smoke"
  },
  "dependencies": {
    "@babel/parser": "^7.26.10",
    "@babel/traverse": "^7.26.10",
    "@babel/types": "^7.26.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "recast": "^0.23.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
